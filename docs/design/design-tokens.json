      "titleSm": { "size": 14, "weight": 600 },
      "bodyLg": { "size": 13, "weight": 600 },
      "bodyMd": { "size": 12, "weight": 500 },
      "bodySm": { "size": 11, "weight": 500 },
      "caption": { "size": 10, "weight": 500 },
      "overline": { "size": 9, "weight": 500 },
      "micro": { "size": 8, "weight": 700 }
    },
    "weights": {
      "bold": 700,
      "semibold": 600,
      "medium": 500,
      "regular": 400
