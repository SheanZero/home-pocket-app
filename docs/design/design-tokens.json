  "components": {
    "card": {
      "radius": 14,
      "padding": 18,
      "borderWidth": 1,
      "light": { "fill": "#FFFFFF", "stroke": "#EFEFEF" },
      "dark": { "fill": "#252836", "stroke": "#353845" }
    },
    "bottomNav": {
      "pillHeight": 62,
      "pillRadius": 32,
      "fabSize": 62,
      "fabRadius": 31,
      "gap": 12,
      "activeTabFill": "#E85A4F",
      "activeTabRadius": 14,
      "inactiveColor": { "light": "#C4C4C4", "dark": "#6B6E7A" }
    },
    "ledgerRow": {
      "radius": 12,
      "padding": [10, 14],
      "gap": 8,
      "tagRadius": 3,
      "tagPadding": [1, 6],
      "survival": { "amount": "#5A9CC8", "tagBg": "#E8F0F8", "tagBgDark": "#1E2D3D" },
      "soul": { "amount": "#47B88A", "tagBg": "#E5F5ED", "tagBgDark": "#1E3028" },
      "shared": { "amount": "#D4845A", "tagBg": "#FFF0E0", "tagBgDark": "#3D2D1E" }
    },
    "transactionRow": {
      "padding": [10, 14],
      "gap": 8,
      "dividerHeight": 1
    },
    "memberAvatar": {
      "size": 24,
      "radius": 12,
      "strokeWidth": 2,
      "overlap": -6,
      "colors": ["#5A9CC8", "#E85A4F", "#8A9178"]
    },
    "familyBadge": {
      "radius": 8,
      "padding": [4, 10],
      "gap": 4,
      "fill": "#E85A4F",
      "bgLight": "#FEF5F4",
      "bgDark": "#3D2525"
    }
  },
  "layout": {
    "screenWidth": 402,
    "groupHeight": 1015,
    "soloHeight": 894,
    "statusBarHeight": 54,
    "contentPadding": 28,
    "sectionGap": 16
